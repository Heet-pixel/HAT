PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/sal_v4?retryWrites=true&w=majority

JWT_ACCESS_SECRET=replace_with_random_64_char_string_here_sal_access
JWT_REFRESH_SECRET=replace_with_random_64_char_string_here_sal_refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# This app serves both the frontend and the API from this same process — so
# genuinely same-origin requests (your deployed URL calling its own /api/*)
# are always allowed automatically, regardless of this setting. This only
# needs to be set if you host the frontend on a DIFFERENT domain than this
# server. On Render, you usually don't need to set this at all — the app
# automatically trusts Render's own RENDER_EXTERNAL_URL (set automatically
# on every Render deploy). Comma-separate multiple origins if needed:
# CORS_ORIGIN=https://your-frontend.example.com,https://another-domain.com
CORS_ORIGIN=https://your-aws-domain.example.com

SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@sal.com
SUPER_ADMIN_PASSWORD=replace_with_strong_unique_password

# Gmail - create an App Password at myaccount.google.com/apppasswords
# (requires 2-Step Verification to be turned ON for the Google account first)
# Google displays it grouped in 4s for readability, e.g. "rojj lciq uenk wldh" —
# remove the spaces before pasting here: GMAIL_APP_PASSWORD=rojjlciquenkwldh
# (the code strips spaces defensively too, but starting clean avoids confusion)
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

BCRYPT_ROUNDS=12
